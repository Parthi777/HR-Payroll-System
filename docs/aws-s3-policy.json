{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SelfieBucketManage",
      "Effect": "Allow",
      "Action": ["s3:CreateBucket", "s3:ListBucket"],
      "Resource": "arn:aws:s3:::hr-payroll-selfies-8d345dca"
    },
    {
      "Sid": "SelfieObjectReadWrite",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::hr-payroll-selfies-8d345dca/*"
    }
  ]
}
