# ─────────────────────────────────────────────────────────────
# AI HR Payroll System — environment template
# Copy to backend/.env (and web/.env.local for NEXT_PUBLIC_* vars).
# Never commit the filled-in .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Backend
NODE_ENV=development
PORT=3001

# Database
# Local dev uses SQLite (zero infra, no Docker):
DATABASE_URL=file:./dev.db
# Production / Railway with Postgres instead — set the schema provider to
# "postgresql" and use a connection string, e.g.:
# DATABASE_URL=postgresql://user:pass@host:5432/hrpayroll

# Redis (only needed once the BullMQ WhatsApp queue is enabled)
REDIS_URL=redis://localhost:6379

# Auth — must be at least 16 characters each
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

# Dev-only: any phone "verifies" with this fixed OTP so login works without an
# SMS/WhatsApp provider. Leave UNSET in production once a real provider is wired.
DEV_FIXED_OTP=123456

# Cloudinary (selfie storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS (face recognition)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REKOGNITION_COLLECTION_ID=hr-payroll-faces

# Face matching threshold (accept if score >= this)
FACE_MATCH_THRESHOLD=85

# WhatsApp provider: wati | twilio | meta
WHATSAPP_PROVIDER=wati
# WATI
WATI_API_URL=https://live-mt-server.wati.io/api/v1
WATI_API_TOKEN=
# OR Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# OR Meta Cloud API
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_VERIFY_TOKEN=

# Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Postgres (only if you run the docker-compose Postgres for production-parity)
POSTGRES_USER=hrpayroll
POSTGRES_PASSWORD=hrpayroll
POSTGRES_DB=hrpayroll

# Frontend (web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
